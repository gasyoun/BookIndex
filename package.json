    "e2e:headed": "playwright test --headed",
    "e2e:report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.0",
    "vite": "^5.4.19",
    "vite-plugin-singlefile": "^2.0.3"
  },
  "dependencies": {
    "fuse.js": "^7.1.0"
  }
}

{
  "name": "bookindex-aaz",
  "version": "2.1.0",
  "private": true,
  "description": "E2E smoke checks for aaz-index standalone app",
  "scripts": {
    "data:split": "python scripts/split_app_data.py app_data.json --out-dir data/modules",
    "data:assemble": "python scripts/assemble_app_data.py --modules-dir data/modules --out app_data.json",
    "import:validate": "python scripts/import_source.py --book-id",
    "import:merge": "python scripts/import_source.py --book-id",
    "import:status": "python scripts/import_source.py --book-id",
    "content:audit": "python scripts/content_report.py app_data.json --write-quality-queue tests/index-audit-queue.json --write-context-pack tests/context-entry-pack.json",
    "check": "npm run typecheck && npm run check:js && npm run check:ui && npm run check:e2e",
    "check:js": "node --check v3_app.js && node --check scripts/build_aaz_index.mjs && node --check scripts/dev/static-server.mjs && node --check scripts/viz/build-viz-cache.js && node --check scripts/viz/viz-state.js",
    "check:ui": "node scripts/check_inline_styles.mjs",
    "check:e2e": "playwright test",
    "build": "node scripts/build_aaz_index.mjs",
    "build:legacy": "python scripts/build_aaz_index.py",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "dev:vite": "vite",
    "build:vite": "vite build && node scripts/vite/postbuild-copy.mjs",
    "preview:vite": "vite preview --outDir dist-vite",
    "serve:static": "node scripts/dev/static-server.mjs 4173",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.0",
    "typescript": "^5.7.3",
    "vite": "^8.0.10",
    "vite-plugin-singlefile": "^2.3.3"
  },
  "dependencies": {
    "fuse.js": "^7.1.0"
  }
}

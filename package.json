{
  "name": "bookindex-aaz",
  "version": "2.1.0",
  "private": true,
  "description": "E2E smoke checks for aaz-index standalone app",
  "scripts": {
    "dev:vite": "vite",
    "build:vite": "vite build && node scripts/vite/postbuild-copy.mjs",
    "preview:vite": "vite preview --outDir dist-vite",

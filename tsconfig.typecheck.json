{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": [
      "ES2020",
      "DOM"
    ],
    "skipLibCheck": true
  },
  "include": [
    "v3_app.js",
    "scripts/viz/build-viz-cache.js",
    "types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "aaz-index.html",
    "dist-vite"
  ]
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gasyoun.github.io/BookIndex/schemas/app_data.schema.json",
  "title": "BookIndex app_data",
  "type": "object",
  "required": [
    "schema_version",
    "names",
    "toponyms",
    "ethnonyms",
    "languages",
    "lexicon",
    "lexicon_reverse",
    "lexicon_tech",
    "subject_index",
    "chapters"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "schema_migrations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "labels": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "colors": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "epoch_labels": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "epoch_colors": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "family_colors": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "corpus": {
      "$ref": "#/$defs/corpusRegistry"
    },
    "names": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/entityItem"
      }
    },
    "toponyms": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/entityItem"
      }
    },
    "ethnonyms": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/entityItem"
      }
    },
    "languages": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/entityItem"
      }
    },
    "lexicon": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/entityItem"
      }
    },
    "lexicon_reverse": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/entityItem"
      }
    },
    "lexicon_tech": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/entityItem"
      }
    },
    "subject_index": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/entityItem"
      }
    },
    "glossary": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/glossaryItem"
      }
    },
    "chapters": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/chapterItem"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/edgeItem"
      }
    },
    "language_edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/edgeItem"
      }
    },
    "cross_links": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/crossLinkItem"
            }
          }
        }
      }
    },
    "book_stats": {
      "type": "object",
      "additionalProperties": true
    },
    "scholar": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true,
  "$defs": {
    "corpusRegistry": {
      "type": "object",
      "properties": {
        "schema_version": {
          "type": "integer",
          "minimum": 1
        },
        "active_book_id": {
          "type": "string",
          "minLength": 1
        },
        "books": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/corpusBook"
          }
        },
        "source_types": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/corpusSourceType"
          }
        }
      },
      "additionalProperties": true
    },
    "corpusBook": {
      "type": "object",
      "required": [
        "book_id"
      ],
      "properties": {
        "book_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z0-9][a-z0-9_-]*$"
        },
        "title": {
          "type": "string"
        },
        "author": {
          "type": "string"
        },
        "year": {
          "type": "integer"
        },
        "edition": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "active",
            "validated",
            "published",
            "planned",
            "archived"
          ]
        },
        "source_type": {
          "type": "string"
        },
        "pages_total": {
          "type": "integer",
          "minimum": 1
        },
        "default_route": {
          "type": "string"
        },
        "content_modules": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "corpusSourceType": {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z0-9][a-z0-9_-]*$"
        },
        "title": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "planned",
            "deprecated"
          ]
        },
        "planned_count": {
          "type": "integer",
          "minimum": 0
        },
        "supports": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "pages",
              "timecodes",
              "transcripts",
              "citations",
              "media"
            ]
          }
        }
      },
      "additionalProperties": true
    },
    "sourceItem": {
      "type": "object",
      "properties": {
        "label": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "quote": {
          "type": "string"
        },
        "page": {
          "oneOf": [
            {
              "type": "integer"
            },
            {
              "type": "string"
            }
          ]
        }
      },
      "additionalProperties": true
    },
    "contextMap": {
      "type": "object",
      "patternProperties": {
        "^[0-9]+$": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "entityItem": {
      "type": "object",
      "properties": {
        "head": {
          "type": "string"
        },
        "page_list": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1
          }
        },
        "contexts": {
          "oneOf": [
            {
              "$ref": "#/$defs/contextMap"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ]
        },
        "sources": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/sourceItem"
          }
        },
        "editorial_flags": {
          "type": "object",
          "properties": {
            "verified": {
              "type": "boolean"
            },
            "suspect": {
              "type": "boolean"
            },
            "source_confirmed": {
              "type": "boolean"
            },
            "note": {
              "type": "string"
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "glossaryItem": {
      "type": "object",
      "properties": {
        "head": {
          "type": "string"
        },
        "term": {
          "type": "string"
        },
        "definition": {
          "type": "string"
        },
        "url": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "chapterItem": {
      "type": "object",
      "required": [
        "name",
        "start",
        "end"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "start": {
          "type": "integer",
          "minimum": 1
        },
        "end": {
          "type": "integer",
          "minimum": 1
        },
        "century": {
          "type": "integer"
        }
      },
      "additionalProperties": true
    },
    "edgeItem": {
      "type": "object",
      "required": [
        "source",
        "target"
      ],
      "properties": {
        "source": {
          "type": "string"
        },
        "target": {
          "type": "string"
        },
        "weight": {
          "type": "number"
        }
      },
      "additionalProperties": true
    },
    "crossLinkItem": {
      "type": "object",
      "properties": {
        "head": {
          "type": "string"
        },
        "weight": {
          "type": "number"
        }
      },
      "additionalProperties": true
    }
  }
}
